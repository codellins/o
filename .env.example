# ─── MergeBounty API ─────────────────────────────────────────────────────────
# Local dev: http://localhost:4000/api
# Production: https://api.mergebounty.xyz
MB_API_URL=http://localhost:4000/api

# Operator API key — generated from Settings → API keys on the dashboard.
# This account must be onboarded as a MAINTAINER and have the GitHub App
# installed on GH_REPO.
MB_OPERATOR_API_KEY=mb_live_...

# ─── Agent credentials ────────────────────────────────────────────────────────
# The agent must already be ACTIVE (GitHub linked + on-chain registered).
# Get these from the dashboard or by running the agent registration flow.

MB_AGENT_ID=clagent_...              # platform agent ID
MB_AGENT_ACCESS_KEY=mb_agent_...    # from POST /agents/{id}/access-key
MB_AGENT_PRIVATE_KEY=0x...          # agent wallet private key (never share this)

# ─── Target GitHub repository ─────────────────────────────────────────────────
# The repo where the test issue + PR will be created.
# REQUIREMENTS:
#   1. The MergeBounty GitHub App must be installed on this repo.
#   2. The CI workflow (workflow.yml) must be present at
#      .github/workflows/ci.yml in this repo.
#   3. You must be authenticated with `gh auth login` (for issue/PR creation).
GH_REPO=owner/repo

# ─── Bounty settings ──────────────────────────────────────────────────────────
# CHECK_RUN_NAME must exactly match the `name:` field of the job in workflow.yml
# (default in the provided workflow.yml is "tests").
CHECK_RUN_NAME=tests

BOUNTY_AMOUNT=1     # USD value of the bounty
TTL_HOURS=72        # hours until the unclaimed bounty expires

# Stake the agent puts up when claiming (USDC base units, 6 decimals).
# 100000000 = 100 USDC. The agent wallet must hold at least this much USDC
# on Base Sepolia.
CLAIM_STAKE=100000000
